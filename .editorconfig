root = true

# ==================== 全局默认值 ====================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ==================== Go 代码 ====================
[*.go]
indent_style = tab
tab_width = 8

# ==================== JavaScript/TypeScript ====================
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# ==================== JSON/YAML ====================
[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ==================== Markdown ====================
[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# ==================== Shell 脚本 ====================
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# ==================== Docker ====================
[{Dockerfile,docker-compose*.yml}]
indent_style = space
indent_size = 2

# ==================== Makefile ====================
[Makefile]
indent_style = tab
tab_width = 8

# ==================== Windows 批处理 ====================
[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf
