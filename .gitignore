# ==================== Markdown 文件 ====================

# 忽略根目录的临时 Markdown 文件
*.md
.qwen
*.exe
config.yaml
# 但保留重要的项目文档
!README.md
!DEPLOYMENT.md
!DOCS.md

# docs 目录的文档全部保留
!docs/*.md

# ==================== 敏感工具（不推送） ====================
# 密码生成工具（包含敏感逻辑）
cmd/tools/
cmd/tools/generate_password.go

# ==================== 依赖目录 ====================
node_modules/
ui/node_modules/

# 构建输出
dist/
ui/dist/
build/
ui/build/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器目录和文件
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 环境变量
.env
.env.local
.env.*.local
!.env.example

# 测试覆盖率
coverage/
*.lcov

# TypeScript 缓存
*.tsbuildinfo

# 临时文件
tmp/
temp/
*.tmp

# 备份文件（可能包含敏感信息）
*.bak
*.backup

# ==================== 测试文件（保留核心测试） ====================
# Go 测试文件 - 保留用于 CI/CD 和质量保证
# *_test.go 不再忽略，允许提交核心测试

# 测试覆盖率输出（不推送）
coverage.out
coverage_partial.out

# 前端测试配置
ui/src/setupTests.ts
ui/jest.config.js

# 测试生成的文件（不推送）
*.test.*
*.spec.*
