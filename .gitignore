# ==================== Markdown 文件 ====================

# 忽略根目录的临时 Markdown 文件
*.md
# 但保留重要的项目文档
!README.md
!DEPLOYMENT.md
!DOCS.md
!KUBEVISION_OPTIMIZATION_TASKS.md

# docs 目录的文档全部保留
!docs/*.md

# ==================== 敏感工具（不推送） ====================
*_test.*
cmd/tools/

# ==================== 配置与密钥 ====================
config.yaml
.env
.env.local
.env.*.local
!.env.example

# ==================== 依赖目录 ====================
node_modules/
ui/node_modules/

# ==================== 构建产物 ====================
dist/
ui/dist/
build/
ui/build/
*.exe
*.out
*.test

# ==================== 日志 ====================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 编辑器 / IDE ====================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ==================== 测试覆盖率 ====================
coverage/
*.lcov
coverage.out
coverage_partial.out
final.out

# ==================== 前端测试文件（不推送） ====================
*.test.*
*.spec.*
ui/src/setupTests.ts
ui/jest.config.js

# ==================== 缓存 / 临时文件 ====================
*.tsbuildinfo
*.tmp
tmp/
temp/
.qwen
.vite/
ui/.vite/

# ==================== 备份文件 ====================
*.bak
*.backup
