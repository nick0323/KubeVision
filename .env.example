# KubeVision 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== 认证配置 ====================
# 登录用户名（可选，默认：admin）
K8SVISION_AUTH_USERNAME=admin

# 登录密码（必填）- 使用 bcrypt 哈希
# 生成方法：go run cmd/tools/generate_password.go <your_password>
# 或使用在线工具：https://bcrypt-generator.com/
K8SVISION_AUTH_PASSWORD=

# 最大登录失败次数（可选，默认：5）
K8SVISION_AUTH_MAX_FAIL=5

# 锁定时间（分钟）（可选，默认：10）
K8SVISION_AUTH_LOCK_MINUTES=10

# ==================== JWT 配置 ====================
# JWT 签名密钥（必填，建议 64 位以上随机字符串）
# 生成方法：openssl rand -base64 64
K8SVISION_JWT_SECRET=

# ==================== 服务器配置 ====================
# 服务器端口（可选，默认：8080）
K8SVISION_SERVER_PORT=8080

# 服务器主机（可选，默认：0.0.0.0）
K8SVISION_SERVER_HOST=0.0.0.0

# ==================== Kubernetes 配置 ====================
# Kubeconfig 文件路径（可选，默认：空，使用 in-cluster 配置）
KUBECONFIG=

# 或使用 API Server 直连方式
K8SVISION_KUBERNETES_APISERVER=
K8SVISION_KUBERNETES_TOKEN=

# ==================== 日志配置 ====================
# 日志级别：debug, info, warn, error（可选，默认：info）
K8SVISION_LOG_LEVEL=info

# 日志格式：json, console（可选，默认：console）
K8SVISION_LOG_FORMAT=console
